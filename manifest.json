{
  "manifest_version": 2,
  "name": "Privacy Tracker Detector",
  "version": "1.0.0",
  "description": "Detecta ameaças à privacidade e rastreamento na navegação web: terceiros, cookies, fingerprinting e hijacking.",

  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "cookies",
    "storage",
    "tabs",
    "activeTab",
    "<all_urls>"
  ],

  "data_collection_permissions": {
    "collect_technical_and_interaction_data": false,
    "collect_personally_identifying_information": false
  },

  "background": {
    "scripts": ["background.js"]
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],

  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "48": "icons/icon.svg",
      "96": "icons/icon.svg"
    },
    "default_title": "Privacy Tracker Detector"
  },

  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  }
}
